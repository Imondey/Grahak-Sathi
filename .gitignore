node_modules/
client/dist/
.env
uploads/

# Per-SKU reference profile images are runtime store assets (per-shop product
# photos), not source — ignore the actual image files but keep the folder so the
# path convention (store-data/reference-images/{shop_id}/{barcode}.jpg) is visible.
store-data/reference-images/*
!store-data/reference-images/.gitkeep

# Post-gate checkout evidence captures (per-shop, transaction-scoped) — runtime
# assets written by /api/checkout/capture. Ignore the images, keep the folder so
# the convention (store-data/checkout-captures/{shop_id}/{txn_ref}.jpg) is visible.
store-data/checkout-captures/*
!store-data/checkout-captures/.gitkeep


# Python bytecode / caches
__pycache__/
*.pyc
*.pyo

# Local env files
.env.local
